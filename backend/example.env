# Database
DB_HOST=mysql
DB_PORT=3306
DB_USER=root
DB_PASSWORD=password
DB_NAME=dental_clinic

# JWT
JWT_SECRET=change-this-to-a-32-char-minimum-secret
JWT_EXPIRY_HOURS=24

# Server
PORT=8080
HOST=0.0.0.0

# Default Admin (used for seeding)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# WhatsApp (Meta Cloud API) - can also be configured via admin UI
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=

# SMTP Email - can also be configured via admin UI
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=

FRONTEND_URL=http://localhost:5173